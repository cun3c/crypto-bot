//@version=5
strategy("1m/5m Crypto Scalping Bot", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// =========================================================================
// 1. INPUTS
// =========================================================================
// Trend Filter
emaLength = input.int(200, title="EMA Trend Length", group="Trend")

// Momentum (Stochastic RSI)
smoothK = input.int(3, "Stoch %K Smoothing", minval=1, group="Momentum")
smoothD = input.int(3, "Stoch %D Smoothing", minval=1, group="Momentum")
lengthRSI = input.int(14, "RSI Length", minval=1, group="Momentum")
lengthStoch = input.int(14, "Stochastic Length", minval=1, group="Momentum")
overbought = input.int(80, "Overbought", group="Momentum")
oversold = input.int(20, "Oversold", group="Momentum")

// Risk Management (ATR based for tight scalping)
atrLength = input.int(14, title="ATR Length", group="Risk Management")
slMultiplier = input.float(1.2, title="Stop Loss ATR Multiplier", step=0.1, group="Risk Management")
rrRatio = input.float(1.5, title="Risk/Reward Ratio (TP multiplier)", step=0.1, group="Risk Management")
webhookSecret = input.string("your_secret_token", title="Webhook Secret", group="Alerts")

// =========================================================================
// 2. INDICATORS & LOGIC
// =========================================================================
// EMA Trend Filter (Trade in direction of major trend)
emaTrend = ta.ema(close, emaLength)
plot(emaTrend, color=color.white, linewidth=2, title="200 EMA")

// Stochastic RSI (Momentum triggers)
rsi1 = ta.rsi(close, lengthRSI)
k = ta.sma(ta.stoch(rsi1, rsi1, rsi1, lengthStoch), smoothK)
d = ta.sma(k, smoothD)

// ATR for dynamic Stop Loss / Take Profit
atr = ta.atr(atrLength)

// Conditions
// LONG: Price above 200 EMA + Stoch RSI cross UP in oversold territory
longCondition = (close > emaTrend) and ta.crossover(k, d) and (k < oversold)

// SHORT: Price below 200 EMA + Stoch RSI cross DOWN in overbought territory
shortCondition = (close < emaTrend) and ta.crossunder(k, d) and (k > overbought)

// =========================================================================
// 3. EXECUTION & ALERTS
// =========================================================================
if (longCondition and strategy.position_size == 0)
    sl_price = close - (atr * slMultiplier)
    tp_price = close + (atr * slMultiplier * rrRatio)
    
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=sl_price, limit=tp_price)
    
    // Webhook JSON Payload
    alert_msg = '{"secret": "' + webhookSecret + '", "symbol": "' + syminfo.ticker + '", "action": "BUY", "strategy": "Scalper_1m_5m", "timeframe": "' + timeframe.period + '", "price": ' + str.tostring(close) + ', "stop_loss": ' + str.tostring(sl_price) + ', "take_profit": ' + str.tostring(tp_price) + '}'
    alert(alert_msg, alert.freq_once_per_bar_close)

if (shortCondition and strategy.position_size == 0)
    sl_price = close + (atr * slMultiplier)
    tp_price = close - (atr * slMultiplier * rrRatio)
    
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=sl_price, limit=tp_price)
    
    // Webhook JSON Payload
    alert_msg = '{"secret": "' + webhookSecret + '", "symbol": "' + syminfo.ticker + '", "action": "SELL", "strategy": "Scalper_1m_5m", "timeframe": "' + timeframe.period + '", "price": ' + str.tostring(close) + ', "stop_loss": ' + str.tostring(sl_price) + ', "take_profit": ' + str.tostring(tp_price) + '}'
    alert(alert_msg, alert.freq_once_per_bar_close)
