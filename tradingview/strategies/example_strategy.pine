//@version=5
strategy("EMA Cross Bot Alert", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// Inputs
fastLength = input.int(9, "Fast EMA")
slowLength = input.int(21, "Slow EMA")
risk_pct = input.float(1.0, "Risk %", minval=0.1, step=0.1)

// Calculate EMAs
fastEMA = ta.ema(close, fastLength)
slowEMA = ta.ema(close, slowLength)

// Plot EMAs
plot(fastEMA, color=color.blue, title="Fast EMA")
plot(slowEMA, color=color.orange, title="Slow EMA")

// Conditions
longCondition = ta.crossover(fastEMA, slowEMA)
shortCondition = ta.crossunder(fastEMA, slowEMA)

// Stop Loss Calculation (ATR based)
atr = ta.atr(14)
sl_dist = atr * 2

// Execute Trades & Send Alerts
if (longCondition)
    sl_price = close - sl_dist
    tp_price = close + (sl_dist * 2)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=sl_price, limit=tp_price)
    
    // JSON Payload string
    alert_msg = '{"secret": "your_secret_token", "symbol": "' + syminfo.ticker + '", "action": "BUY", "strategy": "EMA_Cross_Bot", "timeframe": "' + timeframe.period + '", "price": ' + str.tostring(close) + ', "stop_loss": ' + str.tostring(sl_price) + ', "take_profit": ' + str.tostring(tp_price) + '}'
    alert(alert_msg, alert.freq_once_per_bar_close)

if (shortCondition)
    sl_price = close + sl_dist
    tp_price = close - (sl_dist * 2)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=sl_price, limit=tp_price)
    
    alert_msg = '{"secret": "your_secret_token", "symbol": "' + syminfo.ticker + '", "action": "SELL", "strategy": "EMA_Cross_Bot", "timeframe": "' + timeframe.period + '", "price": ' + str.tostring(close) + ', "stop_loss": ' + str.tostring(sl_price) + ', "take_profit": ' + str.tostring(tp_price) + '}'
    alert(alert_msg, alert.freq_once_per_bar_close)
